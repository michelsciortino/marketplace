{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "michelsciortino-marketplace",
  "description": "My personal marketplace for testing and development. Not an official Anthropic marketplace.",
  "owner": {
    "name": "@michelsciortino"
  },
  "plugins": [
    {
      "name": "dart-lsp",
      "description": "Dart/Flutter language server",
      "version": "1.0.1",
      "author": {
        "name": "@michelsciortino"
      },
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/michelsciortino/claude-plugins.git",
        "path": "external_plugins/dart-lsp",
        "ref": "main"
      },
      "category": "development",
      "strict": false,
      "lspServers": {
        "dart": {
          "command": "dart",
          "args": [
            "language-server"
          ],
          "extensionToLanguage": {
            ".dart": "dart"
          }
        }
      },
      "tags": [
        "community-managed"
      ]
    },
    {
      "name": "docbase",
      "description": "Documentation-driven development system that enforces docs as the sole source of truth, with automatic cross-reference integrity checking and doc↔code consistency enforcement.",
      "version": "1.2.0",
      "author": {
        "name": "@michelsciortino"
      },
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/michelsciortino/claude-plugins.git",
        "path": "external_plugins/docbase",
        "ref": "main"
      },
      "category": "development",
      "strict": false,
      "tags": [
        "community-managed",
        "documentation",
        "workflow"
      ]
    },
    {
      "name": "flutter-clean-architecture",
      "description": "Flutter Clean Architecture skill system following Google's official architecture guidelines",
      "version": "1.0.0",
      "author": {
        "name": "@michelsciortino"
      },
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/michelsciortino/claude-plugins.git",
        "path": "external_plugins/flutter-clean-architecture",
        "ref": "main"
      },
      "category": "development",
      "strict": false,
      "tags": [
        "community-managed",
        "flutter",
        "dart"
      ]
    }
  ]
}
